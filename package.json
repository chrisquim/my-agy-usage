{
  "name": "my-agy-usage",
  "displayName": "My Antigravity Usage",
  "description": "A lightweight, status bar only quota monitor for Antigravity AI.",
  "version": "1.0.0",
  "publisher": "devcoramdeo",
  "icon": "dev.coramdeo_profile.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/coramdeo643/my-agy-usage.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "myAgyUsage.refresh",
        "title": "Refresh Quota Data",
        "category": "Antigravity Lite"
      },
      {
        "command": "myAgyUsage.setPinnedModel",
        "title": "Set Pinned Model",
        "category": "Antigravity Lite"
      }
    ],
    "keybindings": [
      {
        "command": "myAgyUsage.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "configuration": {
      "title": "My Antigravity Usage",
      "properties": {
        "myAgyUsage.refreshInterval": {
          "type": "number",
          "default": 120,
          "minimum": 10,
          "maximum": 3600,
          "description": "Interval in seconds to refresh quota data (10-3600)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "tsc -noEmit",
    "watch": "npm run esbuild-base -- --sourcemap --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0"
  }
}